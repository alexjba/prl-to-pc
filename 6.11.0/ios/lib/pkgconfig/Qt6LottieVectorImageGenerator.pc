prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LottieVectorImageGenerator
Description: Qt6LottieVectorImageGenerator module
Version: 6.11.0
Libs: -F${libdir} -framework QtLottieVectorImageGenerator
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLottieVectorImageGenerator.framework/Headers -DQT_LOTTIEVECTORIMAGEGENERATOR_LIB
