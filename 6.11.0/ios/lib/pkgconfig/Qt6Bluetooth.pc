prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Bluetooth
Description: Qt6Bluetooth module
Version: 6.11.0
Libs: -F${libdir} -framework QtBluetooth -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtBluetooth.framework/Headers -DQT_BLUETOOTH_LIB
Requires: Qt6Core
