prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsSynchronizer
Description: Qt6LabsSynchronizer module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsSynchronizer -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsSynchronizer.framework/Headers -DQT_LABSSYNCHRONIZER_LIB
Requires: Qt6Core
