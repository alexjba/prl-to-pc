prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6StateMachineQml
Description: Qt6StateMachineQml module
Version: 6.11.0
Libs: -F${libdir} -framework QtStateMachineQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtStateMachineQml.framework/Headers -DQT_STATEMACHINEQML_LIB
Requires: Qt6Network Qt6Core
