prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Core
Description: Qt6Core module
Version: 6.11.0
Libs: -F${libdir} -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtCore.framework/Headers -DQT_CORE_LIB
