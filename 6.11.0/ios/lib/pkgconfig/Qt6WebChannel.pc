prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebChannel
Description: Qt6WebChannel module
Version: 6.11.0
Libs: -F${libdir} -framework QtWebChannel -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtWebChannel.framework/Headers -DQT_WEBCHANNEL_LIB
Requires: Qt6Core
