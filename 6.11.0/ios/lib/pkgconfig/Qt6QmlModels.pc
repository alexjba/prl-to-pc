prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlModels
Description: Qt6QmlModels module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlModels -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlModels.framework/Headers -DQT_QMLMODELS_LIB
Requires: Qt6Network Qt6Core
