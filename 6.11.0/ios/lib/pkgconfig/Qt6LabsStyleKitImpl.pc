prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsStyleKitImpl
Description: Qt6LabsStyleKitImpl module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsStyleKitImpl -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsStyleKitImpl.framework/Headers -DQT_LABSSTYLEKITIMPL_LIB
Requires: Qt6Core
