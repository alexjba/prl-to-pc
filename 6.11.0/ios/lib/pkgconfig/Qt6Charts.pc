prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Charts
Description: Qt6Charts module
Version: 6.11.0
Libs: -F${libdir} -framework QtCharts -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtCharts.framework/Headers -DQT_CHARTS_LIB
Requires: Qt6Core
