prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsFolderListModel
Description: Qt6LabsFolderListModel module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsFolderListModel -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsFolderListModel.framework/Headers -DQT_LABSFOLDERLISTMODEL_LIB
Requires: Qt6Core
