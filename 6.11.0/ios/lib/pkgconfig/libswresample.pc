prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: libswresample
Description: libswresample module
Version: 6.11.0
Libs: -F${libdir} -framework libswresample
Cflags: -F${libdir} -I${includedir} -I${libdir}/libswresample.framework/Headers -DQT_LIBSWRESAMPLE_LIB
