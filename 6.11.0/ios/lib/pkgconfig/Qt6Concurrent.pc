prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Concurrent
Description: Qt6Concurrent module
Version: 6.11.0
Libs: -F${libdir} -framework QtConcurrent -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtConcurrent.framework/Headers -DQT_CONCURRENT_LIB
Requires: Qt6Core
