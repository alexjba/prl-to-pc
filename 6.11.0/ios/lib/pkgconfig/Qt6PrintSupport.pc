prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6PrintSupport
Description: Qt6PrintSupport module
Version: 6.11.0
Libs: -F${libdir} -framework QtPrintSupport -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtPrintSupport.framework/Headers -DQT_PRINTSUPPORT_LIB
Requires: Qt6Core
