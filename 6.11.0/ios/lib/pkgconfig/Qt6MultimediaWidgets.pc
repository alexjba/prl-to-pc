prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6MultimediaWidgets
Description: Qt6MultimediaWidgets module
Version: 6.11.0
Libs: -F${libdir} -framework QtMultimediaWidgets -framework QtGui -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtMultimediaWidgets.framework/Headers -DQT_MULTIMEDIAWIDGETS_LIB
Requires: Qt6Gui Qt6Core
