prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardSettings
Description: Qt6VirtualKeyboardSettings module
Version: 6.11.0
Libs: -F${libdir} -framework QtVirtualKeyboardSettings -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtVirtualKeyboardSettings.framework/Headers -DQT_VIRTUALKEYBOARDSETTINGS_LIB
Requires: Qt6Core
