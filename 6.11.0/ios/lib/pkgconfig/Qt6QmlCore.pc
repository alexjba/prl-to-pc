prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlCore
Description: Qt6QmlCore module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlCore -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlCore.framework/Headers -DQT_QMLCORE_LIB
Requires: Qt6Network Qt6Core
