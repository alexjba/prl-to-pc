prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: libswscale
Description: libswscale module
Version: 6.11.0
Libs: -F${libdir} -framework libswscale
Cflags: -F${libdir} -I${includedir} -I${libdir}/libswscale.framework/Headers -DQT_LIBSWSCALE_LIB
