prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: libavformat
Description: libavformat module
Version: 6.11.0
Libs: -F${libdir} -framework libavformat
Cflags: -F${libdir} -I${includedir} -I${libdir}/libavformat.framework/Headers -DQT_LIBAVFORMAT_LIB
