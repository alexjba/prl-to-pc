prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlNetwork
Description: Qt6QmlNetwork module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlNetwork -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlNetwork.framework/Headers -DQT_QMLNETWORK_LIB
Requires: Qt6Network Qt6Core
