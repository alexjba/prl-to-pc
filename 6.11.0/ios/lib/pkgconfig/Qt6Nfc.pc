prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Nfc
Description: Qt6Nfc module
Version: 6.11.0
Libs: -F${libdir} -framework QtNfc -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtNfc.framework/Headers -DQT_NFC_LIB
Requires: Qt6Core
