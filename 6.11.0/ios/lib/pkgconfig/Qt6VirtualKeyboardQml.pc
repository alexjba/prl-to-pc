prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardQml
Description: Qt6VirtualKeyboardQml module
Version: 6.11.0
Libs: -F${libdir} -framework QtVirtualKeyboardQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtVirtualKeyboardQml.framework/Headers -DQT_VIRTUALKEYBOARDQML_LIB
Requires: Qt6Network Qt6Core
