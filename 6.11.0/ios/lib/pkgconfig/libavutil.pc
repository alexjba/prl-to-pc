prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: libavutil
Description: libavutil module
Version: 6.11.0
Libs: -F${libdir} -framework libavutil
Cflags: -F${libdir} -I${includedir} -I${libdir}/libavutil.framework/Headers -DQT_LIBAVUTIL_LIB
