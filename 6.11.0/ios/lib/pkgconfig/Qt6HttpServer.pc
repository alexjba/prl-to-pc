prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6HttpServer
Description: Qt6HttpServer module
Version: 6.11.0
Libs: -F${libdir} -framework QtHttpServer -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtHttpServer.framework/Headers -DQT_HTTPSERVER_LIB
Requires: Qt6Core
