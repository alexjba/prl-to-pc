prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Svg
Description: Qt6Svg module
Version: 6.11.0
Libs: -F${libdir} -framework QtSvg -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtSvg.framework/Headers -DQT_SVG_LIB
Requires: Qt6Core
