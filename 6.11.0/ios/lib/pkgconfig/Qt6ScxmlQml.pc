prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ScxmlQml
Description: Qt6ScxmlQml module
Version: 6.11.0
Libs: -F${libdir} -framework QtScxmlQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtScxmlQml.framework/Headers -DQT_SCXMLQML_LIB
Requires: Qt6Network Qt6Core
