prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DSpatialAudio
Description: Qt6Quick3DSpatialAudio module
Version: 6.11.0
Libs: -F${libdir} -framework QtQuick3DSpatialAudio
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQuick3DSpatialAudio.framework/Headers -DQT_QUICK3DSPATIALAUDIO_LIB
