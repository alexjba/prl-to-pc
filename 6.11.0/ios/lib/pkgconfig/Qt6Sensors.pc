prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Sensors
Description: Qt6Sensors module
Version: 6.11.0
Libs: -F${libdir} -framework QtSensors -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtSensors.framework/Headers -DQT_SENSORS_LIB
Requires: Qt6Core
