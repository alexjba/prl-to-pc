prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt63DCore
Description: Qt63DCore module
Version: 6.11.0
Libs: -F${libdir} -framework Qt3DCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/Qt3DCore.framework/Headers -DQT_3DCORE_LIB
