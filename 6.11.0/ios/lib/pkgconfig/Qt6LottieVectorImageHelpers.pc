prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LottieVectorImageHelpers
Description: Qt6LottieVectorImageHelpers module
Version: 6.11.0
Libs: -F${libdir} -framework QtLottieVectorImageHelpers -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLottieVectorImageHelpers.framework/Headers -DQT_LOTTIEVECTORIMAGEHELPERS_LIB
Requires: Qt6Core
