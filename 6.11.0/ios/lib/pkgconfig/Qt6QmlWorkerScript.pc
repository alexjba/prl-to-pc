prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlWorkerScript
Description: Qt6QmlWorkerScript module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlWorkerScript -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlWorkerScript.framework/Headers -DQT_QMLWORKERSCRIPT_LIB
Requires: Qt6Network Qt6Core
