prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlXmlListModel
Description: Qt6QmlXmlListModel module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlXmlListModel -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlXmlListModel.framework/Headers -DQT_QMLXMLLISTMODEL_LIB
Requires: Qt6Network Qt6Core
