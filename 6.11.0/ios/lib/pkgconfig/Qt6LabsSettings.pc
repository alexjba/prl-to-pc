prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsSettings
Description: Qt6LabsSettings module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsSettings -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsSettings.framework/Headers -DQT_LABSSETTINGS_LIB
Requires: Qt6Core
