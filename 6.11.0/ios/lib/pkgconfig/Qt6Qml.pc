prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Qml
Description: Qt6Qml module
Version: 6.11.0
Libs: -F${libdir} -framework QtQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQml.framework/Headers -DQT_QML_LIB
Requires: Qt6Network Qt6Core
