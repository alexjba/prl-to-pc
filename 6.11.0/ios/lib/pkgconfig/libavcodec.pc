prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: libavcodec
Description: libavcodec module
Version: 6.11.0
Libs: -F${libdir} -framework libavcodec
Cflags: -F${libdir} -I${includedir} -I${libdir}/libavcodec.framework/Headers -DQT_LIBAVCODEC_LIB
