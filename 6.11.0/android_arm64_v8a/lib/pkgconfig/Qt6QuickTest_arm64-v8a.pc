prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickTest_arm64-v8a
Description: Qt6QuickTest_arm64-v8a module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickTest_arm64-v8a -lQt6Test_arm64-v8a -lQt6Core_arm64-v8a -llog -pthread
Cflags: -I${includedir} -I${includedir}/QtQuickTest -DQT_QUICKTEST_LIB
Requires: Qt6Test_arm64-v8a Qt6Core_arm64-v8a
