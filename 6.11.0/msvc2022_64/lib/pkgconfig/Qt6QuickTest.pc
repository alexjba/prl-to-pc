prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickTest
Description: Qt6QuickTest module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickTest
Cflags: -I${includedir} -I${includedir}/QtQuickTest -DQT_QUICKTEST_LIB
Requires: Qt6Core Qt6Test Qt6Gui Qt6Qml Qt6Quick
