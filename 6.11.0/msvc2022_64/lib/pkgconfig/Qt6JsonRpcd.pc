prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6JsonRpcd
Description: Qt6JsonRpcd module
Version: 6.11.0
Libs: -L${libdir} -lQt6JsonRpcd ${libdir}/Qt6Cored.lib -lmpr -luserenv
Cflags: -I${includedir} -I${includedir}/QtJsonRpcd -DQT_JSONRPCD_LIB
