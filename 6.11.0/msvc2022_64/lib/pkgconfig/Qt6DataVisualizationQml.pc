prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DataVisualizationQml
Description: Qt6DataVisualizationQml module
Version: 6.11.0
Libs: -L${libdir} -lQt6DataVisualizationQml
Cflags: -I${includedir} -I${includedir}/QtDataVisualizationQml -DQT_DATAVISUALIZATIONQML_LIB
Requires: Qt6Core Qt6Gui Qt6OpenGL Qt6Qml Qt6Quick Qt6DataVisualization
