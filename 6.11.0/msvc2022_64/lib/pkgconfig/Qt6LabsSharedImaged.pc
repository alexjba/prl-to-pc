prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsSharedImaged
Description: Qt6LabsSharedImaged module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsSharedImaged
Cflags: -I${includedir} -I${includedir}/QtLabsSharedImaged -DQT_LABSSHAREDIMAGED_LIB
