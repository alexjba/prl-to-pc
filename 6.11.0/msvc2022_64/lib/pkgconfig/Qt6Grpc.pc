prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Grpc
Description: Qt6Grpc module
Version: 6.11.0
Libs: -L${libdir} -lQt6Grpc
Cflags: -I${includedir} -I${includedir}/QtGrpc -DQT_GRPC_LIB
Requires: Qt6Core Qt6Protobuf Qt6Network
