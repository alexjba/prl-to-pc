prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6StateMachined
Description: Qt6StateMachined module
Version: 6.11.0
Libs: -L${libdir} -lQt6StateMachined
Cflags: -I${includedir} -I${includedir}/QtStateMachined -DQT_STATEMACHINED_LIB
