prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ProtobufQuick
Description: Qt6ProtobufQuick module
Version: 6.11.0
Libs: -L${libdir} -lQt6ProtobufQuick
Cflags: -I${includedir} -I${includedir}/QtProtobufQuick -DQT_PROTOBUFQUICK_LIB
Requires: Qt6Quick Qt6Core Qt6Protobuf Qt6Qml
