prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6OpenGLWidgets
Description: Qt6OpenGLWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6OpenGLWidgets
Cflags: -I${includedir} -I${includedir}/QtOpenGLWidgets -DQT_OPENGLWIDGETS_LIB
Requires: Qt6OpenGL Qt6Widgets
