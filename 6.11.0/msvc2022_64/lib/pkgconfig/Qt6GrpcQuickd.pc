prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6GrpcQuickd
Description: Qt6GrpcQuickd module
Version: 6.11.0
Libs: -L${libdir} -lQt6GrpcQuickd
Cflags: -I${includedir} -I${includedir}/QtGrpcQuickd -DQT_GRPCQUICKD_LIB
