prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6GraphsWidgetsd
Description: Qt6GraphsWidgetsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6GraphsWidgetsd
Cflags: -I${includedir} -I${includedir}/QtGraphsWidgetsd -DQT_GRAPHSWIDGETSD_LIB
