prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Networkd
Description: Qt6Networkd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Networkd
Cflags: -I${includedir} -I${includedir}/QtNetworkd -DQT_NETWORKD_LIB
