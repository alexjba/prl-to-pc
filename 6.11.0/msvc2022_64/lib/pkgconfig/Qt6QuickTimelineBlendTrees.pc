prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickTimelineBlendTrees
Description: Qt6QuickTimelineBlendTrees module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickTimelineBlendTrees
Cflags: -I${includedir} -I${includedir}/QtQuickTimelineBlendTrees -DQT_QUICKTIMELINEBLENDTREES_LIB
Requires: Qt6Core Qt6Qml Qt6Quick Qt6QuickTimeline
