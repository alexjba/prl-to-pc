prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ChartsQmld
Description: Qt6ChartsQmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6ChartsQmld
Cflags: -I${includedir} -I${includedir}/QtChartsQmld -DQT_CHARTSQMLD_LIB
