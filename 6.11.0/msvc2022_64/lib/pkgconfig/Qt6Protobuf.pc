prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Protobuf
Description: Qt6Protobuf module
Version: 6.11.0
Libs: -L${libdir} -lQt6Protobuf
Cflags: -I${includedir} -I${includedir}/QtProtobuf -DQT_PROTOBUF_LIB
Requires: Qt6Core
