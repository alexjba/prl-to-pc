prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlModelsd
Description: Qt6QmlModelsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlModelsd
Cflags: -I${includedir} -I${includedir}/QtQmlModelsd -DQT_QMLMODELSD_LIB
