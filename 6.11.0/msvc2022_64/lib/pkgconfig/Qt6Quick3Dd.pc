prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3Dd
Description: Qt6Quick3Dd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3Dd
Cflags: -I${includedir} -I${includedir}/QtQuick3Dd -DQT_QUICK3DD_LIB
