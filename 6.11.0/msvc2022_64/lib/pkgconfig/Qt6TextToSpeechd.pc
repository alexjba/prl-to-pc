prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6TextToSpeechd
Description: Qt6TextToSpeechd module
Version: 6.11.0
Libs: -L${libdir} -lQt6TextToSpeechd
Cflags: -I${includedir} -I${includedir}/QtTextToSpeechd -DQT_TEXTTOSPEECHD_LIB
