prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6StateMachine
Description: Qt6StateMachine module
Version: 6.11.0
Libs: -L${libdir} -lQt6StateMachine
Cflags: -I${includedir} -I${includedir}/QtStateMachine -DQT_STATEMACHINE_LIB
Requires: Qt6Core Qt6Gui
