prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebSocketsd
Description: Qt6WebSocketsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebSocketsd
Cflags: -I${includedir} -I${includedir}/QtWebSocketsd -DQT_WEBSOCKETSD_LIB
