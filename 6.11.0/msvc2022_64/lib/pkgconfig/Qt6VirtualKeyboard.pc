prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboard
Description: Qt6VirtualKeyboard module
Version: 6.11.0
Libs: -L${libdir} -lQt6VirtualKeyboard
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboard -DQT_VIRTUALKEYBOARD_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick
