prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6MultimediaQuickd
Description: Qt6MultimediaQuickd module
Version: 6.11.0
Libs: -L${libdir} -lQt6MultimediaQuickd
Cflags: -I${includedir} -I${includedir}/QtMultimediaQuickd -DQT_MULTIMEDIAQUICKD_LIB
