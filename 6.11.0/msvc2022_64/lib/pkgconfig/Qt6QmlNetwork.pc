prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlNetwork
Description: Qt6QmlNetwork module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlNetwork
Cflags: -I${includedir} -I${includedir}/QtQmlNetwork -DQT_QMLNETWORK_LIB
Requires: Qt6Core Qt6Network Qt6Qml
