prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ChartsQml
Description: Qt6ChartsQml module
Version: 6.11.0
Libs: -L${libdir} -lQt6ChartsQml
Cflags: -I${includedir} -I${includedir}/QtChartsQml -DQT_CHARTSQML_LIB
Requires: Qt6Charts Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6OpenGL
