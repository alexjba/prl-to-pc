prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebEngineCore
Description: Qt6WebEngineCore module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebEngineCore
Cflags: -I${includedir} -I${includedir}/QtWebEngineCore -DQT_WEBENGINECORE_LIB
Requires: Qt6Core Qt6Gui Qt6Network Qt6Quick Qt6WebChannel Qt6Positioning
