prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsPlatformd
Description: Qt6LabsPlatformd module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsPlatformd
Cflags: -I${includedir} -I${includedir}/QtLabsPlatformd -DQT_LABSPLATFORMD_LIB
