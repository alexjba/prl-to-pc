prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Sql
Description: Qt6Sql module
Version: 6.11.0
Libs: -L${libdir} -lQt6Sql
Cflags: -I${includedir} -I${includedir}/QtSql -DQT_SQL_LIB
Requires: Qt6Core
