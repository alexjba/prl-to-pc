prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Bluetoothd
Description: Qt6Bluetoothd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Bluetoothd
Cflags: -I${includedir} -I${includedir}/QtBluetoothd -DQT_BLUETOOTHD_LIB
