prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SvgWidgets
Description: Qt6SvgWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6SvgWidgets
Cflags: -I${includedir} -I${includedir}/QtSvgWidgets -DQT_SVGWIDGETS_LIB
Requires: Qt6Core Qt6Gui Qt6Svg Qt6Widgets
