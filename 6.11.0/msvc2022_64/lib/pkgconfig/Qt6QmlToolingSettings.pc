prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlToolingSettings
Description: Qt6QmlToolingSettings module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlToolingSettings ${libdir}/Qt6Core.lib -lmpr -luserenv
Cflags: -I${includedir} -I${includedir}/QtQmlToolingSettings -DQT_QMLTOOLINGSETTINGS_LIB
