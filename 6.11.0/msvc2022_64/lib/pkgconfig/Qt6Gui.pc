prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Gui
Description: Qt6Gui module
Version: 6.11.0
Libs: -L${libdir} -lQt6Gui
Cflags: -I${includedir} -I${includedir}/QtGui -DQT_GUI_LIB
Requires: Qt6Core
