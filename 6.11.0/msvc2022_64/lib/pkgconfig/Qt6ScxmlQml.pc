prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ScxmlQml
Description: Qt6ScxmlQml module
Version: 6.11.0
Libs: -L${libdir} -lQt6ScxmlQml
Cflags: -I${includedir} -I${includedir}/QtScxmlQml -DQT_SCXMLQML_LIB
Requires: Qt6Core Qt6Qml Qt6Scxml
