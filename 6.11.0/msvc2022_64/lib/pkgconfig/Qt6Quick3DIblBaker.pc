prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DIblBaker
Description: Qt6Quick3DIblBaker module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DIblBaker
