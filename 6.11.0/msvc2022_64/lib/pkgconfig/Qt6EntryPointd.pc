prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6EntryPointd
Description: Qt6EntryPointd module
Version: 6.11.0
Libs: -L${libdir} -lQt6EntryPointd -lshell32
Cflags: -I${includedir} -I${includedir}/QtEntryPointd -DQT_ENTRYPOINTD_LIB
