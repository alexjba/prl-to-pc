prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Graphs
Description: Qt6Graphs module
Version: 6.11.0
Libs: -L${libdir} -lQt6Graphs
Cflags: -I${includedir} -I${includedir}/QtGraphs -DQT_GRAPHS_LIB
Requires: Qt6Core Qt6Gui Qt6Quick Qt6Quick3D Qt6QuickShapes Qt6Quick3DRuntimeRender
