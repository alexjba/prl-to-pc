prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SensorsQuick
Description: Qt6SensorsQuick module
Version: 6.11.0
Libs: -L${libdir} -lQt6SensorsQuick
Cflags: -I${includedir} -I${includedir}/QtSensorsQuick -DQT_SENSORSQUICK_LIB
Requires: Qt6Core Qt6Qml Qt6Sensors
