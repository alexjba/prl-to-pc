prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickControls2d
Description: Qt6QuickControls2d module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickControls2d
Cflags: -I${includedir} -I${includedir}/QtQuickControls2d -DQT_QUICKCONTROLS2D_LIB
