prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DHelpers
Description: Qt6Quick3DHelpers module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DHelpers
Cflags: -I${includedir} -I${includedir}/QtQuick3DHelpers -DQT_QUICK3DHELPERS_LIB
Requires: Qt6Qml Qt6Quick Qt6Quick3D Qt6Gui Qt6Concurrent
