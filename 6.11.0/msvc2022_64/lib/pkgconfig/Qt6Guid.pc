prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Guid
Description: Qt6Guid module
Version: 6.11.0
Libs: -L${libdir} -lQt6Guid
Cflags: -I${includedir} -I${includedir}/QtGuid -DQT_GUID_LIB
