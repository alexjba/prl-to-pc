prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DBusd
Description: Qt6DBusd module
Version: 6.11.0
Libs: -L${libdir} -lQt6DBusd
Cflags: -I${includedir} -I${includedir}/QtDBusd -DQT_DBUSD_LIB
