prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebSockets
Description: Qt6WebSockets module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebSockets
Cflags: -I${includedir} -I${includedir}/QtWebSockets -DQT_WEBSOCKETS_LIB
Requires: Qt6Core Qt6Network
