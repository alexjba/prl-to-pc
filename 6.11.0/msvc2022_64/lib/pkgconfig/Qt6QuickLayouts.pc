prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickLayouts
Description: Qt6QuickLayouts module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickLayouts
Cflags: -I${includedir} -I${includedir}/QtQuickLayouts -DQT_QUICKLAYOUTS_LIB
Requires: Qt6Core Qt6Qml Qt6Gui Qt6Quick
