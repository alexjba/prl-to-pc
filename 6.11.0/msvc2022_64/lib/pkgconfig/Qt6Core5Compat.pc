prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Core5Compat
Description: Qt6Core5Compat module
Version: 6.11.0
Libs: -L${libdir} -lQt6Core5Compat
Cflags: -I${includedir} -I${includedir}/QtCore5Compat -DQT_CORE5COMPAT_LIB
Requires: Qt6Core
