prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebView
Description: Qt6WebView module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebView
Cflags: -I${includedir} -I${includedir}/QtWebView -DQT_WEBVIEW_LIB
Requires: Qt6Core Qt6Gui
