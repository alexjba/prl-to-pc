prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Nfcd
Description: Qt6Nfcd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Nfcd
Cflags: -I${includedir} -I${includedir}/QtNfcd -DQT_NFCD_LIB
