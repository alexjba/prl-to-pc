prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Network
Description: Qt6Network module
Version: 6.11.0
Libs: -L${libdir} -lQt6Network
Cflags: -I${includedir} -I${includedir}/QtNetwork -DQT_NETWORK_LIB
Requires: Qt6Core
