prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Positioning
Description: Qt6Positioning module
Version: 6.11.0
Libs: -L${libdir} -lQt6Positioning
Cflags: -I${includedir} -I${includedir}/QtPositioning -DQT_POSITIONING_LIB
Requires: Qt6Core
