prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6PacketProtocol
Description: Qt6PacketProtocol module
Version: 6.11.0
Libs: -L${libdir} -lQt6PacketProtocol ${libdir}/Qt6Core.lib -lmpr -luserenv
Cflags: -I${includedir} -I${includedir}/QtPacketProtocol -DQT_PACKETPROTOCOL_LIB
