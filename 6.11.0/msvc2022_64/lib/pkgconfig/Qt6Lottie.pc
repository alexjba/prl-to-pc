prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Lottie
Description: Qt6Lottie module
Version: 6.11.0
Libs: -L${libdir} -lQt6Lottie
Cflags: -I${includedir} -I${includedir}/QtLottie -DQT_LOTTIE_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick
