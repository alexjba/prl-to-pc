prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Help
Description: Qt6Help module
Version: 6.11.0
Libs: -L${libdir} -lQt6Help
Cflags: -I${includedir} -I${includedir}/QtHelp -DQT_HELP_LIB
Requires: Qt6Core Qt6Sql Qt6Gui Qt6Widgets
