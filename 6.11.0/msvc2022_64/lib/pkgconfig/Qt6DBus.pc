prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DBus
Description: Qt6DBus module
Version: 6.11.0
Libs: -L${libdir} -lQt6DBus
Cflags: -I${includedir} -I${includedir}/QtDBus -DQT_DBUS_LIB
Requires: Qt6Core
