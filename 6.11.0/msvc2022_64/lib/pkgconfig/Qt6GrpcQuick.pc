prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6GrpcQuick
Description: Qt6GrpcQuick module
Version: 6.11.0
Libs: -L${libdir} -lQt6GrpcQuick
Cflags: -I${includedir} -I${includedir}/QtGrpcQuick -DQT_GRPCQUICK_LIB
Requires: Qt6Quick Qt6Core Qt6Grpc Qt6QmlNetwork
