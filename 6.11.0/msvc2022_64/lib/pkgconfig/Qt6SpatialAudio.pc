prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SpatialAudio
Description: Qt6SpatialAudio module
Version: 6.11.0
Libs: -L${libdir} -lQt6SpatialAudio
Cflags: -I${includedir} -I${includedir}/QtSpatialAudio -DQT_SPATIALAUDIO_LIB
Requires: Qt6Multimedia
