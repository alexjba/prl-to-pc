prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Sensorsd
Description: Qt6Sensorsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Sensorsd
Cflags: -I${includedir} -I${includedir}/QtSensorsd -DQT_SENSORSD_LIB
