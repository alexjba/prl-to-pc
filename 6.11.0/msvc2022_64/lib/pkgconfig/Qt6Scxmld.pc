prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Scxmld
Description: Qt6Scxmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6Scxmld
Cflags: -I${includedir} -I${includedir}/QtScxmld -DQT_SCXMLD_LIB
