prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickTestd
Description: Qt6QuickTestd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickTestd
Cflags: -I${includedir} -I${includedir}/QtQuickTestd -DQT_QUICKTESTD_LIB
