prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DUtils
Description: Qt6Quick3DUtils module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DUtils
Cflags: -I${includedir} -I${includedir}/QtQuick3DUtils -DQT_QUICK3DUTILS_LIB
Requires: Qt6Core Qt6Gui Qt6Quick
