prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickParticlesd
Description: Qt6QuickParticlesd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickParticlesd
Cflags: -I${includedir} -I${includedir}/QtQuickParticlesd -DQT_QUICKPARTICLESD_LIB
