prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Positioningd
Description: Qt6Positioningd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Positioningd
Cflags: -I${includedir} -I${includedir}/QtPositioningd -DQT_POSITIONINGD_LIB
