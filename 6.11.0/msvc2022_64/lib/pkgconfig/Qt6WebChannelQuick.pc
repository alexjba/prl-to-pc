prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebChannelQuick
Description: Qt6WebChannelQuick module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebChannelQuick
Cflags: -I${includedir} -I${includedir}/QtWebChannelQuick -DQT_WEBCHANNELQUICK_LIB
Requires: Qt6Core Qt6WebChannel
