prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6OpenGLWidgetsd
Description: Qt6OpenGLWidgetsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6OpenGLWidgetsd
Cflags: -I${includedir} -I${includedir}/QtOpenGLWidgetsd -DQT_OPENGLWIDGETSD_LIB
