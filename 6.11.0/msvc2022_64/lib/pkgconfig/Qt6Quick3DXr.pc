prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DXr
Description: Qt6Quick3DXr module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DXr
Cflags: -I${includedir} -I${includedir}/QtQuick3DXr -DQT_QUICK3DXR_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6Quick3D
