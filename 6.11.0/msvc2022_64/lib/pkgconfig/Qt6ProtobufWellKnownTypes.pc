prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ProtobufWellKnownTypes
Description: Qt6ProtobufWellKnownTypes module
Version: 6.11.0
Libs: -L${libdir} -lQt6ProtobufWellKnownTypes
Cflags: -I${includedir} -I${includedir}/QtProtobufWellKnownTypes -DQT_PROTOBUFWELLKNOWNTYPES_LIB
Requires: Qt6Protobuf
