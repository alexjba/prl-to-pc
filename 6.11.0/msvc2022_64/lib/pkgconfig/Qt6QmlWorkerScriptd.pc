prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlWorkerScriptd
Description: Qt6QmlWorkerScriptd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlWorkerScriptd
Cflags: -I${includedir} -I${includedir}/QtQmlWorkerScriptd -DQT_QMLWORKERSCRIPTD_LIB
