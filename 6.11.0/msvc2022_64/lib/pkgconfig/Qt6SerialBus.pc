prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SerialBus
Description: Qt6SerialBus module
Version: 6.11.0
Libs: -L${libdir} -lQt6SerialBus
Cflags: -I${includedir} -I${includedir}/QtSerialBus -DQT_SERIALBUS_LIB
Requires: Qt6Core Qt6Network Qt6SerialPort
