prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ProtobufQtCoreTypes
Description: Qt6ProtobufQtCoreTypes module
Version: 6.11.0
Libs: -L${libdir} -lQt6ProtobufQtCoreTypes
Cflags: -I${includedir} -I${includedir}/QtProtobufQtCoreTypes -DQT_PROTOBUFQTCORETYPES_LIB
Requires: Qt6Core Qt6Protobuf
