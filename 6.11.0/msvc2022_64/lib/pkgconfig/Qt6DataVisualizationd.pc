prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DataVisualizationd
Description: Qt6DataVisualizationd module
Version: 6.11.0
Libs: -L${libdir} -lQt6DataVisualizationd
Cflags: -I${includedir} -I${includedir}/QtDataVisualizationd -DQT_DATAVISUALIZATIOND_LIB
