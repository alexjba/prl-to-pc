prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebViewd
Description: Qt6WebViewd module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebViewd
Cflags: -I${includedir} -I${includedir}/QtWebViewd -DQT_WEBVIEWD_LIB
