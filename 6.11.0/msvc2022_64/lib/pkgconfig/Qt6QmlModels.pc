prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlModels
Description: Qt6QmlModels module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlModels
Cflags: -I${includedir} -I${includedir}/QtQmlModels -DQT_QMLMODELS_LIB
Requires: Qt6Core Qt6Qml
