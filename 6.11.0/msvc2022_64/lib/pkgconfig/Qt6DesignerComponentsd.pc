prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DesignerComponentsd
Description: Qt6DesignerComponentsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6DesignerComponentsd
Cflags: -I${includedir} -I${includedir}/QtDesignerComponentsd -DQT_DESIGNERCOMPONENTSD_LIB
