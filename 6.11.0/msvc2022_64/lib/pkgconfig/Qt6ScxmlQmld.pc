prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ScxmlQmld
Description: Qt6ScxmlQmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6ScxmlQmld
Cflags: -I${includedir} -I${includedir}/QtScxmlQmld -DQT_SCXMLQMLD_LIB
