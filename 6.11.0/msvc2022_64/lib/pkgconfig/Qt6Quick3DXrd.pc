prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DXrd
Description: Qt6Quick3DXrd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DXrd
Cflags: -I${includedir} -I${includedir}/QtQuick3DXrd -DQT_QUICK3DXRD_LIB
