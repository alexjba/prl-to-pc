prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Testd
Description: Qt6Testd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Testd
Cflags: -I${includedir} -I${includedir}/QtTestd -DQT_TESTD_LIB
