prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlLocalStoraged
Description: Qt6QmlLocalStoraged module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlLocalStoraged
Cflags: -I${includedir} -I${includedir}/QtQmlLocalStoraged -DQT_QMLLOCALSTORAGED_LIB
