prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Location
Description: Qt6Location module
Version: 6.11.0
Libs: -L${libdir} -lQt6Location
Cflags: -I${includedir} -I${includedir}/QtLocation -DQT_LOCATION_LIB
Requires: Qt6Core Qt6Positioning Qt6PositioningQuick Qt6Gui Qt6Quick Qt6Qml Qt6QuickShapes
