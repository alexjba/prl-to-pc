prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6PacketProtocold
Description: Qt6PacketProtocold module
Version: 6.11.0
Libs: -L${libdir} -lQt6PacketProtocold ${libdir}/Qt6Cored.lib -lmpr -luserenv
Cflags: -I${includedir} -I${includedir}/QtPacketProtocold -DQT_PACKETPROTOCOLD_LIB
