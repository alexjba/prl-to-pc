prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlDebug
Description: Qt6QmlDebug module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlDebug ${libdir}/Qt6PacketProtocol.lib ${libdir}/Qt6Qml.lib ${libdir}/Qt6Network.lib ${libdir}/Qt6Core.lib -lmpr -luserenv -lws2_32 -lshell32
Cflags: -I${includedir} -I${includedir}/QtQmlDebug -DQT_QMLDEBUG_LIB
