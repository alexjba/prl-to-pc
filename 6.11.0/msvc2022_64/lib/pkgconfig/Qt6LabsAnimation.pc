prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsAnimation
Description: Qt6LabsAnimation module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsAnimation
Cflags: -I${includedir} -I${includedir}/QtLabsAnimation -DQT_LABSANIMATION_LIB
Requires: Qt6Qml Qt6Quick
