prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickVectorImage
Description: Qt6QuickVectorImage module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickVectorImage
Cflags: -I${includedir} -I${includedir}/QtQuickVectorImage -DQT_QUICKVECTORIMAGE_LIB
Requires: Qt6Quick Qt6Svg
