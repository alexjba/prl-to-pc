prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Sqld
Description: Qt6Sqld module
Version: 6.11.0
Libs: -L${libdir} -lQt6Sqld
Cflags: -I${includedir} -I${includedir}/QtSqld -DQT_SQLD_LIB
