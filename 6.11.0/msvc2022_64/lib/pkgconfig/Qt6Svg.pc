prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Svg
Description: Qt6Svg module
Version: 6.11.0
Libs: -L${libdir} -lQt6Svg
Cflags: -I${includedir} -I${includedir}/QtSvg -DQT_SVG_LIB
Requires: Qt6Core Qt6Gui
