prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6MultimediaQuick
Description: Qt6MultimediaQuick module
Version: 6.11.0
Libs: -L${libdir} -lQt6MultimediaQuick
Cflags: -I${includedir} -I${includedir}/QtMultimediaQuick -DQT_MULTIMEDIAQUICK_LIB
