prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DPhysicsHelpersd
Description: Qt6Quick3DPhysicsHelpersd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DPhysicsHelpersd
Cflags: -I${includedir} -I${includedir}/QtQuick3DPhysicsHelpersd -DQT_QUICK3DPHYSICSHELPERSD_LIB
