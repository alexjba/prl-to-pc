prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Graphsd
Description: Qt6Graphsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Graphsd
Cflags: -I${includedir} -I${includedir}/QtGraphsd -DQT_GRAPHSD_LIB
