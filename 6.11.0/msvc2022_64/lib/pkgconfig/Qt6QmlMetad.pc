prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlMetad
Description: Qt6QmlMetad module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlMetad
Cflags: -I${includedir} -I${includedir}/QtQmlMetad -DQT_QMLMETAD_LIB
