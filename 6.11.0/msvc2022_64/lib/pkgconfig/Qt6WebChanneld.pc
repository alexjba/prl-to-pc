prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebChanneld
Description: Qt6WebChanneld module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebChanneld
Cflags: -I${includedir} -I${includedir}/QtWebChanneld -DQT_WEBCHANNELD_LIB
