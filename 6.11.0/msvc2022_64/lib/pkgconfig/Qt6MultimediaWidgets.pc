prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6MultimediaWidgets
Description: Qt6MultimediaWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6MultimediaWidgets
Cflags: -I${includedir} -I${includedir}/QtMultimediaWidgets -DQT_MULTIMEDIAWIDGETS_LIB
Requires: Qt6Core Qt6Gui Qt6Multimedia Qt6Widgets
