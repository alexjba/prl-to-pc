prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6CanvasPainter
Description: Qt6CanvasPainter module
Version: 6.11.0
Libs: -L${libdir} -lQt6CanvasPainter
Cflags: -I${includedir} -I${includedir}/QtCanvasPainter -DQT_CANVASPAINTER_LIB
Requires: Qt6Core Qt6Gui Qt6Quick Qt6Widgets
