prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SpatialAudiod
Description: Qt6SpatialAudiod module
Version: 6.11.0
Libs: -L${libdir} -lQt6SpatialAudiod
Cflags: -I${includedir} -I${includedir}/QtSpatialAudiod -DQT_SPATIALAUDIOD_LIB
