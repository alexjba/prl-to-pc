prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlNetworkd
Description: Qt6QmlNetworkd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlNetworkd
Cflags: -I${includedir} -I${includedir}/QtQmlNetworkd -DQT_QMLNETWORKD_LIB
