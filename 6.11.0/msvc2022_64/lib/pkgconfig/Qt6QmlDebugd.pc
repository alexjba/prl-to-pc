prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlDebugd
Description: Qt6QmlDebugd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlDebugd ${libdir}/Qt6PacketProtocold.lib ${libdir}/Qt6Qmld.lib ${libdir}/Qt6Networkd.lib ${libdir}/Qt6Cored.lib -lmpr -luserenv -lws2_32 -lshell32
Cflags: -I${includedir} -I${includedir}/QtQmlDebugd -DQT_QMLDEBUGD_LIB
