prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickWidgets
Description: Qt6QuickWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickWidgets
Cflags: -I${includedir} -I${includedir}/QtQuickWidgets -DQT_QUICKWIDGETS_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6Widgets
