prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Chartsd
Description: Qt6Chartsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Chartsd
Cflags: -I${includedir} -I${includedir}/QtChartsd -DQT_CHARTSD_LIB
