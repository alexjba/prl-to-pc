prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardd
Description: Qt6VirtualKeyboardd module
Version: 6.11.0
Libs: -L${libdir} -lQt6VirtualKeyboardd
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboardd -DQT_VIRTUALKEYBOARDD_LIB
