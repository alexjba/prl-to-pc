prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Protobufd
Description: Qt6Protobufd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Protobufd
Cflags: -I${includedir} -I${includedir}/QtProtobufd -DQT_PROTOBUFD_LIB
