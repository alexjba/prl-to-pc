prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardSettings
Description: Qt6VirtualKeyboardSettings module
Version: 6.11.0
Libs: -L${libdir} -lQt6VirtualKeyboardSettings
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboardSettings -DQT_VIRTUALKEYBOARDSETTINGS_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6VirtualKeyboard
