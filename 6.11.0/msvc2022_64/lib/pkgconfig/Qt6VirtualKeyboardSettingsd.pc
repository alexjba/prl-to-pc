prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardSettingsd
Description: Qt6VirtualKeyboardSettingsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6VirtualKeyboardSettingsd
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboardSettingsd -DQT_VIRTUALKEYBOARDSETTINGSD_LIB
