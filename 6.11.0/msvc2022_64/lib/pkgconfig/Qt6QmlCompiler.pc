prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlCompiler
Description: Qt6QmlCompiler module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlCompiler
Cflags: -I${includedir} -I${includedir}/QtQmlCompiler -DQT_QMLCOMPILER_LIB
Requires: Qt6Core Qt6Qml
