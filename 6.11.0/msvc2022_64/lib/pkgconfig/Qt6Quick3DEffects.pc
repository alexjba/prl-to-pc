prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DEffects
Description: Qt6Quick3DEffects module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DEffects
Cflags: -I${includedir} -I${includedir}/QtQuick3DEffects -DQT_QUICK3DEFFECTS_LIB
Requires: Qt6Qml Qt6Quick Qt6Quick3D
