prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SerialPortd
Description: Qt6SerialPortd module
Version: 6.11.0
Libs: -L${libdir} -lQt6SerialPortd
Cflags: -I${includedir} -I${includedir}/QtSerialPortd -DQT_SERIALPORTD_LIB
