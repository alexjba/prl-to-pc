prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebEngineWidgets
Description: Qt6WebEngineWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebEngineWidgets
Cflags: -I${includedir} -I${includedir}/QtWebEngineWidgets -DQT_WEBENGINEWIDGETS_LIB
Requires: Qt6Core Qt6Gui Qt6Widgets Qt6WebEngineCore Qt6QuickWidgets Qt6Quick Qt6PrintSupport
