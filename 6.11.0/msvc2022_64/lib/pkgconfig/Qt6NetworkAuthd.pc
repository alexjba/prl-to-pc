prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6NetworkAuthd
Description: Qt6NetworkAuthd module
Version: 6.11.0
Libs: -L${libdir} -lQt6NetworkAuthd
Cflags: -I${includedir} -I${includedir}/QtNetworkAuthd -DQT_NETWORKAUTHD_LIB
