prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Svgd
Description: Qt6Svgd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Svgd
Cflags: -I${includedir} -I${includedir}/QtSvgd -DQT_SVGD_LIB
