prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsAnimationd
Description: Qt6LabsAnimationd module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsAnimationd
Cflags: -I${includedir} -I${includedir}/QtLabsAnimationd -DQT_LABSANIMATIOND_LIB
