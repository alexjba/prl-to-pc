prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlXmlListModel
Description: Qt6QmlXmlListModel module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlXmlListModel
Cflags: -I${includedir} -I${includedir}/QtQmlXmlListModel -DQT_QMLXMLLISTMODEL_LIB
Requires: Qt6Core Qt6Qml Qt6QmlModels
