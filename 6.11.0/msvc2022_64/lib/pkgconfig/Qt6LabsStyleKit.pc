prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsStyleKit
Description: Qt6LabsStyleKit module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsStyleKit
Cflags: -I${includedir} -I${includedir}/QtLabsStyleKit -DQT_LABSSTYLEKIT_LIB
Requires: Qt6Gui Qt6Quick Qt6QuickTemplates2 Qt6QuickControls2Impl
