prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebViewQuickd
Description: Qt6WebViewQuickd module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebViewQuickd
Cflags: -I${includedir} -I${includedir}/QtWebViewQuickd -DQT_WEBVIEWQUICKD_LIB
