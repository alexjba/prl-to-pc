prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlWorkerScript
Description: Qt6QmlWorkerScript module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlWorkerScript
Cflags: -I${includedir} -I${includedir}/QtQmlWorkerScript -DQT_QMLWORKERSCRIPT_LIB
Requires: Qt6Core Qt6Qml
