prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickVectorImageHelpersd
Description: Qt6QuickVectorImageHelpersd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickVectorImageHelpersd
Cflags: -I${includedir} -I${includedir}/QtQuickVectorImageHelpersd -DQT_QUICKVECTORIMAGEHELPERSD_LIB
