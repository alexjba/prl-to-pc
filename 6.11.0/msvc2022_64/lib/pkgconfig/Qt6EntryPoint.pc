prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6EntryPoint
Description: Qt6EntryPoint module
Version: 6.11.0
Libs: -L${libdir} -lQt6EntryPoint -lshell32
Cflags: -I${includedir} -I${includedir}/QtEntryPoint -DQT_ENTRYPOINT_LIB
