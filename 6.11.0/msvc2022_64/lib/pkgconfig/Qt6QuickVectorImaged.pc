prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickVectorImaged
Description: Qt6QuickVectorImaged module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickVectorImaged
Cflags: -I${includedir} -I${includedir}/QtQuickVectorImaged -DQT_QUICKVECTORIMAGED_LIB
