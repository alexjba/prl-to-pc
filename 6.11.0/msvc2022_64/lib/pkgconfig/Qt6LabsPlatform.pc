prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsPlatform
Description: Qt6LabsPlatform module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsPlatform
Cflags: -I${includedir} -I${includedir}/QtLabsPlatform -DQT_LABSPLATFORM_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6QuickTemplates2 Qt6Widgets
