prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Scxml
Description: Qt6Scxml module
Version: 6.11.0
Libs: -L${libdir} -lQt6Scxml
Cflags: -I${includedir} -I${includedir}/QtScxml -DQT_SCXML_LIB
Requires: Qt6Core
