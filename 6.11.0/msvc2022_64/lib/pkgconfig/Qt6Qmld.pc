prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Qmld
Description: Qt6Qmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6Qmld
Cflags: -I${includedir} -I${includedir}/QtQmld -DQT_QMLD_LIB
