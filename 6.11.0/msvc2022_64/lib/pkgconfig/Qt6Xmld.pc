prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Xmld
Description: Qt6Xmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6Xmld
Cflags: -I${includedir} -I${includedir}/QtXmld -DQT_XMLD_LIB
