prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlCompilerd
Description: Qt6QmlCompilerd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlCompilerd
Cflags: -I${includedir} -I${includedir}/QtQmlCompilerd -DQT_QMLCOMPILERD_LIB
