prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6HttpServer
Description: Qt6HttpServer module
Version: 6.11.0
Libs: -L${libdir} -lQt6HttpServer
Cflags: -I${includedir} -I${includedir}/QtHttpServer -DQT_HTTPSERVER_LIB
Requires: Qt6Core Qt6Network Qt6WebSockets
