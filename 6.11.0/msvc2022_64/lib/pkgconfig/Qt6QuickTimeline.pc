prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickTimeline
Description: Qt6QuickTimeline module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickTimeline
Cflags: -I${includedir} -I${includedir}/QtQuickTimeline -DQT_QUICKTIMELINE_LIB
Requires: Qt6Core Qt6Qml Qt6Quick
