prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DAssetImport
Description: Qt6Quick3DAssetImport module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DAssetImport
Cflags: -I${includedir} -I${includedir}/QtQuick3DAssetImport -DQT_QUICK3DASSETIMPORT_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick3DUtils
