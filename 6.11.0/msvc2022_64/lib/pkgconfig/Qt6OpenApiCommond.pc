prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6OpenApiCommond
Description: Qt6OpenApiCommond module
Version: 6.11.0
Libs: -L${libdir} -lQt6OpenApiCommond
Cflags: -I${includedir} -I${includedir}/QtOpenApiCommond -DQT_OPENAPICOMMOND_LIB
