prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Helpd
Description: Qt6Helpd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Helpd
Cflags: -I${includedir} -I${includedir}/QtHelpd -DQT_HELPD_LIB
