prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DataVisualization
Description: Qt6DataVisualization module
Version: 6.11.0
Libs: -L${libdir} -lQt6DataVisualization
Cflags: -I${includedir} -I${includedir}/QtDataVisualization -DQT_DATAVISUALIZATION_LIB
Requires: Qt6Core Qt6Gui Qt6OpenGL
