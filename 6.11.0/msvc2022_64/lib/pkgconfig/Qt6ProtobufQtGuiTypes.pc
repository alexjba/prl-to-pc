prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ProtobufQtGuiTypes
Description: Qt6ProtobufQtGuiTypes module
Version: 6.11.0
Libs: -L${libdir} -lQt6ProtobufQtGuiTypes
Cflags: -I${includedir} -I${includedir}/QtProtobufQtGuiTypes -DQT_PROTOBUFQTGUITYPES_LIB
Requires: Qt6ProtobufQtCoreTypes Qt6Core Qt6Gui Qt6Protobuf
