prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6UiToolsd
Description: Qt6UiToolsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6UiToolsd
Cflags: -I${includedir} -I${includedir}/QtUiToolsd -DQT_UITOOLSD_LIB
