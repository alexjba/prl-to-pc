prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsSettingsd
Description: Qt6LabsSettingsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6LabsSettingsd
Cflags: -I${includedir} -I${includedir}/QtLabsSettingsd -DQT_LABSSETTINGSD_LIB
