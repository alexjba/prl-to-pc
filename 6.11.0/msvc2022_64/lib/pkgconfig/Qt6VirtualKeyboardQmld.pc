prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6VirtualKeyboardQmld
Description: Qt6VirtualKeyboardQmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6VirtualKeyboardQmld
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboardQmld -DQT_VIRTUALKEYBOARDQMLD_LIB
