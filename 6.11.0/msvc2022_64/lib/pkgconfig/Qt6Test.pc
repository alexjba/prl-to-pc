prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Test
Description: Qt6Test module
Version: 6.11.0
Libs: -L${libdir} -lQt6Test
Cflags: -I${includedir} -I${includedir}/QtTest -DQT_TEST_LIB
Requires: Qt6Core
