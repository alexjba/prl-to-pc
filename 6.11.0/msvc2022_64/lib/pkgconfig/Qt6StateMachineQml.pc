prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6StateMachineQml
Description: Qt6StateMachineQml module
Version: 6.11.0
Libs: -L${libdir} -lQt6StateMachineQml
Cflags: -I${includedir} -I${includedir}/QtStateMachineQml -DQT_STATEMACHINEQML_LIB
Requires: Qt6Core Qt6Qml Qt6StateMachine
