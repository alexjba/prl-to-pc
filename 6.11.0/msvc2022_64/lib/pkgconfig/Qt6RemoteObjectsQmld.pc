prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6RemoteObjectsQmld
Description: Qt6RemoteObjectsQmld module
Version: 6.11.0
Libs: -L${libdir} -lQt6RemoteObjectsQmld
Cflags: -I${includedir} -I${includedir}/QtRemoteObjectsQmld -DQT_REMOTEOBJECTSQMLD_LIB
