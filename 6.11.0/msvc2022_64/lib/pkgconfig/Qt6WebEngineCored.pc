prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebEngineCored
Description: Qt6WebEngineCored module
Version: 6.11.0
Libs: -L${libdir} -lQt6WebEngineCored
Cflags: -I${includedir} -I${includedir}/QtWebEngineCored -DQT_WEBENGINECORED_LIB
