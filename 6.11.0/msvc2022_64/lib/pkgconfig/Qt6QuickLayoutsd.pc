prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickLayoutsd
Description: Qt6QuickLayoutsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickLayoutsd
Cflags: -I${includedir} -I${includedir}/QtQuickLayoutsd -DQT_QUICKLAYOUTSD_LIB
