prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickShapesDesignHelpers
Description: Qt6QuickShapesDesignHelpers module
Version: 6.11.0
Libs: -L${libdir} -lQt6QuickShapesDesignHelpers
Cflags: -I${includedir} -I${includedir}/QtQuickShapesDesignHelpers -DQT_QUICKSHAPESDESIGNHELPERS_LIB
