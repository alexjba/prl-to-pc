prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Lottied
Description: Qt6Lottied module
Version: 6.11.0
Libs: -L${libdir} -lQt6Lottied
Cflags: -I${includedir} -I${includedir}/QtLottied -DQT_LOTTIED_LIB
