prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Locationd
Description: Qt6Locationd module
Version: 6.11.0
Libs: -L${libdir} -lQt6Locationd
Cflags: -I${includedir} -I${includedir}/QtLocationd -DQT_LOCATIOND_LIB
