prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Quick3DRuntimeRender
Description: Qt6Quick3DRuntimeRender module
Version: 6.11.0
Libs: -L${libdir} -lQt6Quick3DRuntimeRender
Cflags: -I${includedir} -I${includedir}/QtQuick3DRuntimeRender -DQT_QUICK3DRUNTIMERENDER_LIB
Requires: Qt6Core Qt6Gui Qt6Quick Qt6Quick3DUtils Qt6ShaderTools Qt6Concurrent
