prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlToolingSettingsd
Description: Qt6QmlToolingSettingsd module
Version: 6.11.0
Libs: -L${libdir} -lQt6QmlToolingSettingsd ${libdir}/Qt6Cored.lib -lmpr -luserenv
Cflags: -I${includedir} -I${includedir}/QtQmlToolingSettingsd -DQT_QMLTOOLINGSETTINGSD_LIB
