prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6GraphsWidgets
Description: Qt6GraphsWidgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6GraphsWidgets
Cflags: -I${includedir} -I${includedir}/QtGraphsWidgets -DQT_GRAPHSWIDGETS_LIB
Requires: Qt6Graphs Qt6QuickWidgets Qt6Core
