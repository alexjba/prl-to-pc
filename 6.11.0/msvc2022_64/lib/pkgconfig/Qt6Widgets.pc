prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Widgets
Description: Qt6Widgets module
Version: 6.11.0
Libs: -L${libdir} -lQt6Widgets
Cflags: -I${includedir} -I${includedir}/QtWidgets -DQT_WIDGETS_LIB
Requires: Qt6Core Qt6Gui
