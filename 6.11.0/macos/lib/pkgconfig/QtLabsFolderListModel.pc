prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsFolderListModel
Description: QtLabsFolderListModel module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsFolderListModel
Cflags: -I${includedir} -I${includedir}/QtLabsFolderListModel -DQT_LABSFOLDERLISTMODEL_LIB
