prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickParticles
Description: Qt6QuickParticles module
Version: 6.11.0
Libs: -F${libdir} -framework QtQuickParticles
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQuickParticles.framework/Headers -DQT_QUICKPARTICLES_LIB
