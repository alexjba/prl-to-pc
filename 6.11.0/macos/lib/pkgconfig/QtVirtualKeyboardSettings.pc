prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtVirtualKeyboardSettings
Description: QtVirtualKeyboardSettings module
Version: 6.11.0
Libs: -L${libdir} -lQtVirtualKeyboardSettings
Cflags: -I${includedir} -I${includedir}/QtVirtualKeyboardSettings -DQT_VIRTUALKEYBOARDSETTINGS_LIB
