prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsStyleKit
Description: QtLabsStyleKit module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsStyleKit
Cflags: -I${includedir} -I${includedir}/QtLabsStyleKit -DQT_LABSSTYLEKIT_LIB
