prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsSharedImage
Description: QtLabsSharedImage module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsSharedImage
Cflags: -I${includedir} -I${includedir}/QtLabsSharedImage -DQT_LABSSHAREDIMAGE_LIB
