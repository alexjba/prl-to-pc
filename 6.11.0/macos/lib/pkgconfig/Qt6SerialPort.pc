prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SerialPort
Description: Qt6SerialPort module
Version: 6.11.0
Libs: -F${libdir} -framework QtSerialPort -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtSerialPort.framework/Headers -DQT_SERIALPORT_LIB
Requires: Qt6Core
