prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Sql
Description: Qt6Sql module
Version: 6.11.0
Libs: -F${libdir} -framework QtSql -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtSql.framework/Headers -DQT_SQL_LIB
Requires: Qt6Core
