prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsStyleKit
Description: Qt6LabsStyleKit module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsStyleKit -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsStyleKit.framework/Headers -DQT_LABSSTYLEKIT_LIB
Requires: Qt6Core
