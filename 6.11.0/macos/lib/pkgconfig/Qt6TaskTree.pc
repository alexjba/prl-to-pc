prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6TaskTree
Description: Qt6TaskTree module
Version: 6.11.0
Libs: -F${libdir} -framework QtTaskTree -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtTaskTree.framework/Headers -DQT_TASKTREE_LIB
Requires: Qt6Core
