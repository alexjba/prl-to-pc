prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsWavefrontMesh
Description: QtLabsWavefrontMesh module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsWavefrontMesh
Cflags: -I${includedir} -I${includedir}/QtLabsWavefrontMesh -DQT_LABSWAVEFRONTMESH_LIB
