prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtTaskTree
Description: QtTaskTree module
Version: 6.11.0
Libs: -L${libdir} -lQtTaskTree -F${libdir} -framework QtConcurrent -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtTaskTree -DQT_TASKTREE_LIB
