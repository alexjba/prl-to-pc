prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsAnimation
Description: QtLabsAnimation module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsAnimation
Cflags: -I${includedir} -I${includedir}/QtLabsAnimation -DQT_LABSANIMATION_LIB
