prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QmlCompiler
Description: Qt6QmlCompiler module
Version: 6.11.0
Libs: -F${libdir} -framework QtQmlCompiler -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQmlCompiler.framework/Headers -DQT_QMLCOMPILER_LIB
Requires: Qt6Network Qt6Core
