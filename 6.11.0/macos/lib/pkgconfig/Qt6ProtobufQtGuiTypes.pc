prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ProtobufQtGuiTypes
Description: Qt6ProtobufQtGuiTypes module
Version: 6.11.0
Libs: -F${libdir} -framework QtProtobufQtGuiTypes -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtProtobufQtGuiTypes.framework/Headers -DQT_PROTOBUFQTGUITYPES_LIB
Requires: Qt6Core
