prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebEngineCore
Description: Qt6WebEngineCore module
Version: 6.11.0
Libs: -F${libdir} -framework QtWebEngineCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtWebEngineCore.framework/Headers -DQT_WEBENGINECORE_LIB
