prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtPositioning
Description: QtPositioning module
Version: 6.11.0
Libs: -L${libdir} -lQtPositioning -F${libdir} -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtPositioning -DQT_POSITIONING_LIB
