prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Graphs
Description: Qt6Graphs module
Version: 6.11.0
Libs: -F${libdir} -framework QtGraphs -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtGraphs.framework/Headers -DQT_GRAPHS_LIB
Requires: Qt6Core
