prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6ChartsQml
Description: Qt6ChartsQml module
Version: 6.11.0
Libs: -F${libdir} -framework QtChartsQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtChartsQml.framework/Headers -DQT_CHARTSQML_LIB
Requires: Qt6Network Qt6Core
