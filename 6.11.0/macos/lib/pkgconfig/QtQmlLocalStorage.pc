prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQmlLocalStorage
Description: QtQmlLocalStorage module
Version: 6.11.0
Libs: -L${libdir} -lQtQmlLocalStorage -F${libdir} -framework QtSql -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtQmlLocalStorage -DQT_QMLLOCALSTORAGE_LIB
