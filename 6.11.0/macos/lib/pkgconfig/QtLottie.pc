prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLottie
Description: QtLottie module
Version: 6.11.0
Libs: -L${libdir} -lQtLottie
Cflags: -I${includedir} -I${includedir}/QtLottie -DQT_LOTTIE_LIB
