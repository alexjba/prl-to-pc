prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtSerialBus
Description: QtSerialBus module
Version: 6.11.0
Libs: -L${libdir} -lQtSerialBus -F${libdir} -framework QtNetwork -framework QtSerialPort -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtSerialBus -DQT_SERIALBUS_LIB
