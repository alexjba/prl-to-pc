prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickVectorImageGenerator
Description: Qt6QuickVectorImageGenerator module
Version: 6.11.0
Libs: -F${libdir} -framework QtQuickVectorImageGenerator
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQuickVectorImageGenerator.framework/Headers -DQT_QUICKVECTORIMAGEGENERATOR_LIB
