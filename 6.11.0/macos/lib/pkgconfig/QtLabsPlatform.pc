prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtLabsPlatform
Description: QtLabsPlatform module
Version: 6.11.0
Libs: -L${libdir} -lQtLabsPlatform
Cflags: -I${includedir} -I${includedir}/QtLabsPlatform -DQT_LABSPLATFORM_LIB
