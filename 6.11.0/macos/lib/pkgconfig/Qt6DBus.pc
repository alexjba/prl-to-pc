prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DBus
Description: Qt6DBus module
Version: 6.11.0
Libs: -F${libdir} -framework QtDBus -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtDBus.framework/Headers -DQT_DBUS_LIB
Requires: Qt6Core
