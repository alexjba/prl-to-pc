prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6OpenApiCommon
Description: Qt6OpenApiCommon module
Version: 6.11.0
Libs: -F${libdir} -framework QtOpenApiCommon -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtOpenApiCommon.framework/Headers -DQT_OPENAPICOMMON_LIB
Requires: Qt6Core
