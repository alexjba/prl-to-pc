prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt63DExtras
Description: Qt63DExtras module
Version: 6.11.0
Libs: -F${libdir} -framework Qt3DExtras -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/Qt3DExtras.framework/Headers -DQT_3DEXTRAS_LIB
Requires: Qt6Core
