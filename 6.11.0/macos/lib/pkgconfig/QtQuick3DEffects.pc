prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQuick3DEffects
Description: QtQuick3DEffects module
Version: 6.11.0
Libs: -L${libdir} -lQtQuick3DEffects
Cflags: -I${includedir} -I${includedir}/QtQuick3DEffects -DQT_QUICK3DEFFECTS_LIB
