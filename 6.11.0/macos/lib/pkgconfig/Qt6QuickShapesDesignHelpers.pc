prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6QuickShapesDesignHelpers
Description: Qt6QuickShapesDesignHelpers module
Version: 6.11.0
Libs: -F${libdir} -framework QtQuickShapesDesignHelpers
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtQuickShapesDesignHelpers.framework/Headers -DQT_QUICKSHAPESDESIGNHELPERS_LIB
