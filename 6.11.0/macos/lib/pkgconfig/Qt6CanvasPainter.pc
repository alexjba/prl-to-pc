prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6CanvasPainter
Description: Qt6CanvasPainter module
Version: 6.11.0
Libs: -F${libdir} -framework QtCanvasPainter -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtCanvasPainter.framework/Headers -DQT_CANVASPAINTER_LIB
Requires: Qt6Core
