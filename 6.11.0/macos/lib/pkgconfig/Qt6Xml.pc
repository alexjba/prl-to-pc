prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Xml
Description: Qt6Xml module
Version: 6.11.0
Libs: -F${libdir} -framework QtXml -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtXml.framework/Headers -DQT_XML_LIB
Requires: Qt6Core
