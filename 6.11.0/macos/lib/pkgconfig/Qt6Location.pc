prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Location
Description: Qt6Location module
Version: 6.11.0
Libs: -F${libdir} -framework QtLocation -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLocation.framework/Headers -DQT_LOCATION_LIB
Requires: Qt6Core
