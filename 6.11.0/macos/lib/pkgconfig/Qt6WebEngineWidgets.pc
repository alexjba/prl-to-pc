prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6WebEngineWidgets
Description: Qt6WebEngineWidgets module
Version: 6.11.0
Libs: -F${libdir} -framework QtWebEngineWidgets -framework QtGui -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtWebEngineWidgets.framework/Headers -DQT_WEBENGINEWIDGETS_LIB
Requires: Qt6Gui Qt6Core
