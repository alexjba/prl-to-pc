prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6UiTools
Description: Qt6UiTools module
Version: 6.11.0
Libs: -F${libdir} -framework QtUiTools -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtUiTools.framework/Headers -DQT_UITOOLS_LIB
Requires: Qt6Core
