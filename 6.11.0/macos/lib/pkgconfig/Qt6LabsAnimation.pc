prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsAnimation
Description: Qt6LabsAnimation module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsAnimation -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsAnimation.framework/Headers -DQT_LABSANIMATION_LIB
Requires: Qt6Core
