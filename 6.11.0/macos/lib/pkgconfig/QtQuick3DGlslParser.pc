prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQuick3DGlslParser
Description: QtQuick3DGlslParser module
Version: 6.11.0
Libs: -L${libdir} -lQtQuick3DGlslParser -F${libdir} -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtQuick3DGlslParser -DQT_QUICK3DGLSLPARSER_LIB
