prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Lottie
Description: Qt6Lottie module
Version: 6.11.0
Libs: -F${libdir} -framework QtLottie -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLottie.framework/Headers -DQT_LOTTIE_LIB
Requires: Qt6Core
