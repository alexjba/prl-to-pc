prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsSharedImage
Description: Qt6LabsSharedImage module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsSharedImage -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsSharedImage.framework/Headers -DQT_LABSSHAREDIMAGE_LIB
Requires: Qt6Core
