prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt3DQuickLogic
Description: Qt3DQuickLogic module
Version: 6.11.0
Libs: -L${libdir} -lQt3DQuickLogic
Cflags: -I${includedir} -I${includedir}/QtDQuickLogic -DQT_DQUICKLOGIC_LIB
