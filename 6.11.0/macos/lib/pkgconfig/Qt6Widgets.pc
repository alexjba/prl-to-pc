prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Widgets
Description: Qt6Widgets module
Version: 6.11.0
Libs: -F${libdir} -framework QtWidgets -framework QtGui -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtWidgets.framework/Headers -DQT_WIDGETS_LIB
Requires: Qt6Gui Qt6Core
