prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DesignerComponents
Description: Qt6DesignerComponents module
Version: 6.11.0
Libs: -F${libdir} -framework QtDesignerComponents
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtDesignerComponents.framework/Headers -DQT_DESIGNERCOMPONENTS_LIB
