prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQuickDialogs2Utils
Description: QtQuickDialogs2Utils module
Version: 6.11.0
Libs: -L${libdir} -lQtQuickDialogs2Utils -F${libdir} -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtQuickDialogs2Utils -DQT_QUICKDIALOGS2UTILS_LIB
