prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtGrpc
Description: QtGrpc module
Version: 6.11.0
Libs: -L${libdir} -lQtGrpc -F${libdir} -framework QtProtobuf -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtGrpc -DQT_GRPC_LIB
