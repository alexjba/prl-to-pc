prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Multimedia
Description: Qt6Multimedia module
Version: 6.11.0
Libs: -F${libdir} -framework QtMultimedia -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtMultimedia.framework/Headers -DQT_MULTIMEDIA_LIB
Requires: Qt6Core
