prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtProtobufQtGuiTypes
Description: QtProtobufQtGuiTypes module
Version: 6.11.0
Libs: -L${libdir} -lQtProtobufQtGuiTypes -F${libdir} -framework QtProtobufQtCoreTypes
Cflags: -I${includedir} -I${includedir}/QtProtobufQtGuiTypes -DQT_PROTOBUFQTGUITYPES_LIB
