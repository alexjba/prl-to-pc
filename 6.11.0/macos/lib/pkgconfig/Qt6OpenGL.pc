prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6OpenGL
Description: Qt6OpenGL module
Version: 6.11.0
Libs: -F${libdir} -framework QtOpenGL -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtOpenGL.framework/Headers -DQT_OPENGL_LIB
Requires: Qt6Core
