prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Core5Compat
Description: Qt6Core5Compat module
Version: 6.11.0
Libs: -F${libdir} -framework QtCore5Compat
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtCore5Compat.framework/Headers -DQT_CORE5COMPAT_LIB
