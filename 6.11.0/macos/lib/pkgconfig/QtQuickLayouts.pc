prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQuickLayouts
Description: QtQuickLayouts module
Version: 6.11.0
Libs: -L${libdir} -lQtQuickLayouts -F${libdir} -framework QtQml -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtQuickLayouts -DQT_QUICKLAYOUTS_LIB
