prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtScxmlQml
Description: QtScxmlQml module
Version: 6.11.0
Libs: -L${libdir} -lQtScxmlQml -F${libdir} -framework QtQml -framework QtNetwork -framework QtScxml -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtScxmlQml -DQT_SCXMLQML_LIB
