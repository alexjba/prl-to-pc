prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtRemoteObjects
Description: QtRemoteObjects module
Version: 6.11.0
Libs: -L${libdir} -lQtRemoteObjects -F${libdir} -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtRemoteObjects -DQT_REMOTEOBJECTS_LIB
