prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6LabsQmlModels
Description: Qt6LabsQmlModels module
Version: 6.11.0
Libs: -F${libdir} -framework QtLabsQmlModels -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtLabsQmlModels.framework/Headers -DQT_LABSQMLMODELS_LIB
Requires: Qt6Network Qt6Core
