prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtQuickControls2Fusion
Description: QtQuickControls2Fusion module
Version: 6.11.0
Libs: -L${libdir} -lQtQuickControls2Fusion
Cflags: -I${includedir} -I${includedir}/QtQuickControls2Fusion -DQT_QUICKCONTROLS2FUSION_LIB
