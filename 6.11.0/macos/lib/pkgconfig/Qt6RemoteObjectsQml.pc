prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6RemoteObjectsQml
Description: Qt6RemoteObjectsQml module
Version: 6.11.0
Libs: -F${libdir} -framework QtRemoteObjectsQml -framework QtNetwork -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtRemoteObjectsQml.framework/Headers -DQT_REMOTEOBJECTSQML_LIB
Requires: Qt6Network Qt6Core
