prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6SvgWidgets
Description: Qt6SvgWidgets module
Version: 6.11.0
Libs: -F${libdir} -framework QtSvgWidgets -framework QtGui -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtSvgWidgets.framework/Headers -DQT_SVGWIDGETS_LIB
Requires: Qt6Gui Qt6Core
