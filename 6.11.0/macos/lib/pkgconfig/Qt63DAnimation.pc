prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt63DAnimation
Description: Qt63DAnimation module
Version: 6.11.0
Libs: -F${libdir} -framework Qt3DAnimation -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/Qt3DAnimation.framework/Headers -DQT_3DANIMATION_LIB
Requires: Qt6Core
