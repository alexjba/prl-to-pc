prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6GraphsWidgets
Description: Qt6GraphsWidgets module
Version: 6.11.0
Libs: -F${libdir} -framework QtGraphsWidgets -framework QtGui -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtGraphsWidgets.framework/Headers -DQT_GRAPHSWIDGETS_LIB
Requires: Qt6Gui Qt6Core
