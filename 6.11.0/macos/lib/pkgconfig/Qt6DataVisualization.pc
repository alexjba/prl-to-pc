prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6DataVisualization
Description: Qt6DataVisualization module
Version: 6.11.0
Libs: -F${libdir} -framework QtDataVisualization -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtDataVisualization.framework/Headers -DQT_DATAVISUALIZATION_LIB
Requires: Qt6Core
