prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtHttpServer
Description: QtHttpServer module
Version: 6.11.0
Libs: -L${libdir} -lQtHttpServer -F${libdir} -framework QtWebSockets -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtHttpServer -DQT_HTTPSERVER_LIB
