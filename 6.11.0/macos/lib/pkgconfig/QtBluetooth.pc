prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtBluetooth
Description: QtBluetooth module
Version: 6.11.0
Libs: -L${libdir} -lQtBluetooth -F${libdir} -framework QtNetwork -framework QtCore -framework IOKit -framework DiskArbitration -framework UniformTypeIdentifiers
Cflags: -I${includedir} -I${includedir}/QtBluetooth -DQT_BLUETOOTH_LIB
