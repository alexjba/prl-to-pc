prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Help
Description: Qt6Help module
Version: 6.11.0
Libs: -F${libdir} -framework QtHelp -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtHelp.framework/Headers -DQT_HELP_LIB
Requires: Qt6Core
