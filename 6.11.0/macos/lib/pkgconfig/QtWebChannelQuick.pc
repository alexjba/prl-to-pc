prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: QtWebChannelQuick
Description: QtWebChannelQuick module
Version: 6.11.0
Libs: -L${libdir} -lQtWebChannelQuick
Cflags: -I${includedir} -I${includedir}/QtWebChannelQuick -DQT_WEBCHANNELQUICK_LIB
