prefix=@@QT_PREFIX@@
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
host_bins=${prefix}/bin

Name: Qt6Designer
Description: Qt6Designer module
Version: 6.11.0
Libs: -F${libdir} -framework QtDesigner -framework QtCore
Cflags: -F${libdir} -I${includedir} -I${libdir}/QtDesigner.framework/Headers -DQT_DESIGNER_LIB
Requires: Qt6Core
